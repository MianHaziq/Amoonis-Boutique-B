// Amoon Bloom — mobile ecommerce API (Express + Prisma)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// REGIONS (multi-region support)
// ============================================

/// A storefront region (e.g. UAE, Saudi Arabia). Regions are data, not an enum, so the
/// admin can add new ones at runtime with no schema migration. `code` is the short token
/// the mobile app sends in the `X-Region` header (e.g. "UAE", "SA"). Exactly one region
/// should have `isDefault = true`; it is used when the client sends no/unknown region.
model Region {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  name_ar   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   ProductRegion[]
  categories CategoryRegion[]
  banners    BannerRegion[]
  sections   SectionRegion[]
  users      User[]
  orders     Order[]

  @@index([isActive])
  @@index([sortOrder])
}

/// Join: which regions a product is visible in. A row per (product, region) pair —
/// "both regions" = two rows, "UAE only" = one row. No rows = visible in none.
model ProductRegion {
  productId String
  regionId  String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([productId, regionId])
  @@index([regionId])
}

model CategoryRegion {
  categoryId String
  regionId   String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([categoryId, regionId])
  @@index([regionId])
}

model BannerRegion {
  bannerId  String
  regionId  String
  createdAt DateTime @default(now())

  banner BannerImage @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  region Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([bannerId, regionId])
  @@index([regionId])
}

model SectionRegion {
  sectionId String
  regionId  String
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([sectionId, regionId])
  @@index([regionId])
}

// ============================================
// USER & ADMIN
// ============================================

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  fullName           String?
  password           String?
  googleId           String?             @unique
  appleId            String?             @unique
  avatar             String?
  role               UserRole            @default(CUSTOMER)
  managerTitle       String?
  managerPermissions ManagerPermission[] @default([])
  status             UserStatus          @default(ACTIVE)
  isEmailVerified    Boolean             @default(false)
  preferredLanguage  String?
  phone              String?
  /// Region the user belongs to (captured from X-Region at signup). Drives which
  /// regional catalog they browse by default. Nullable for legacy users (backfilled).
  regionId           String?
  addressCountry     String?
  addressCity        String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  /// Bumped to invalidate all currently-issued access tokens for this user.
  /// New JWTs include this value as `tv`; verifyToken rejects mismatches.
  /// Backwards compatible: legacy tokens without `tv` are still accepted
  /// during the rollout window.
  tokenVersion       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  cart      Cart?
  orders    Order[]
  addresses Address[]

  pushDevices             UserPushDevice[]
  notificationPreferences UserNotificationPreferences?
  notifications           Notification[]

  promoCodeUsages PromoCodeUsage[]
  userContacts    UserContact[]
  refreshTokens   RefreshToken[]

  region Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([regionId])
}

/// Server-side refresh-token store. The raw token is shown to the client once
/// in the auth response and is never persisted in plaintext — only its SHA-256
/// hash. Rotating on every refresh and revoking on logout/password-change is
/// what gives long-lived sessions a safe revocation path.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  /// Tracks which device requested the original sign-in (informational only).
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// SECTIONS (admin-created blocks for user panel, e.g. Ramadan Deals)
// ============================================

model Section {
  id        String        @id @default(uuid())
  title     String
  title_ar  String?
  image     String?
  sortOrder Int           @default(0)
  status    PublishStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products   SectionProduct[]
  categories SectionCategory[]
  regions    SectionRegion[]

  @@index([sortOrder])
  @@index([status])
}

model SectionProduct {
  id        String   @id @default(uuid())
  sectionId String
  productId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sectionId, productId])
  @@index([sectionId])
  @@index([productId])
}

model SectionCategory {
  id         String   @id @default(uuid())
  sectionId  String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sectionId, categoryId])
  @@index([sectionId])
  @@index([categoryId])
}

// ============================================
// LANDING BANNERS
// ============================================

model BannerImage {
  id        String        @id @default(uuid())
  url       String        @db.Text
  sortOrder Int           @default(0)
  status    PublishStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  regions BannerRegion[]

  @@index([sortOrder])
  @@index([status])
}

// ============================================
// SETTINGS
// ============================================

model Settings {
  id              String   @id @default("default")
  siteName        String   @default("Amoon Bloom")
  logo            String?
  contactEmail    String   @default("contact@example.com")
  supportEmail    String   @default("support@example.com")
  currency        String   @default("USD")
  maintenanceMode Boolean  @default(false)
  hiddenPages     String[] @default([])
  updatedAt       DateTime @updatedAt
}

// ============================================
// CONTACT
// ============================================

/// Contact / issue submitted by an authenticated user. Always tied to a User
/// so the admin sees who sent it (name, email, phone) via the join.
model UserContact {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String   @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CATEGORY & PRODUCT
// ============================================

model Category {
  id             String        @id @default(uuid())
  title          String
  title_ar       String?
  description    String?       @db.Text
  description_ar String?       @db.Text
  image          String?
  totalProducts  Int           @default(0)
  status         PublishStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  products            Product[]
  sectionCategories   SectionCategory[]
  promoCodeCategories PromoCodeCategory[]
  regions             CategoryRegion[]

  @@index([title])
  @@index([status])
}

model Product {
  id              String        @id @default(uuid())
  title           String
  title_ar        String?
  subtitle        String?
  subtitle_ar     String?
  price           Decimal       @db.Decimal(10, 2)
  discountedPrice Decimal?      @db.Decimal(10, 2)
  quantity        Int           @default(0)
  categoryId      String?
  status          PublishStatus @default(DRAFT)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images            ProductImage[]
  descriptions      ProductDescription[]
  productOptions    ProductOption[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  sectionProducts   SectionProduct[]
  promoCodeProducts PromoCodeProduct[]
  regions           ProductRegion[]

  @@index([categoryId])
  @@index([title])
  // Composite serves the hot storefront query: WHERE status='PUBLISHED' ORDER BY createdAt DESC.
  // Leftmost prefix also covers plain status-equality filters/counts.
  @@index([status, createdAt])
}

model ProductOption {
  id         String   @id @default(uuid())
  productId  String
  title      String
  title_ar   String?
  options    String[]
  options_ar String[] @default([])
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductDescription {
  id             String   @id @default(uuid())
  productId      String
  title          String?  @db.Text
  title_ar       String?  @db.Text
  description    String   @db.Text
  description_ar String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

// ============================================
// SAVED ADDRESSES
// ============================================

model Address {
  id            String   @id @default(uuid())
  userId        String
  label         String?
  fullName      String?
  phone         String?
  streetAddress String?
  apartment     String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([userId, isDefault])
}

// ============================================
// CART
// ============================================

model Cart {
  id           String   @id @default(uuid())
  userId       String   @unique
  orderMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  message   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ============================================
// ORDER
// ============================================

model Order {
  id                    String        @id @default(uuid())
  userId                String
  orderMessage          String?       @db.Text
  totalAmount           Decimal       @db.Decimal(10, 2)
  discountAmount        Decimal?      @db.Decimal(10, 2)
  appliedPromoCode      String?
  appliedPromoCodeId    String?
  paymentMethod         PaymentMethod @default(COD)
  status                OrderStatus   @default(PENDING)
  /// Online-payment state. COD orders stay UNPAID until delivered/collected; MyFatoorah orders flip to PAID once GetPaymentStatus confirms it.
  paymentStatus         PaymentStatus @default(UNPAID)
  /// MyFatoorah InvoiceId returned by SendPayment (the payment we created for this order). Null for COD.
  paymentInvoiceId      String?
  /// MyFatoorah transaction/payment id captured at confirmation (from GetPaymentStatus). Null for COD.
  paymentTransactionId  String?
  /// Soft ref to the saved Address used at checkout (may be null for legacy orders or if address was deleted).
  addressId             String?
  /// Address snapshot — copied from the saved or inline address at checkout time so order history stays accurate.
  shippingFullName      String?
  shippingPhone         String?
  shippingStreetAddress String?
  shippingApartment     String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  /// When true, Product.quantity has been reduced for this order’s line items (set on PENDING→CONFIRMED; cleared on cancel/revert).
  inventoryDeducted     Boolean       @default(false)
  /// Whether placing this order should clear the user's cart. True for normal cart checkout;
  /// false for "Buy Now" (single-product direct purchase) so the cart is left untouched.
  clearCartOnPayment    Boolean       @default(true)
  /// Region the order was placed in (captured from X-Region / the user's region at checkout).
  /// Drives region-scoped analytics. Nullable for legacy orders (backfilled to default region).
  regionId              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  address      Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  appliedPromo PromoCode?  @relation(fields: [appliedPromoCodeId], references: [id], onDelete: SetNull)
  region       Region?     @relation(fields: [regionId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@index([createdAt, status])
  @@index([addressId])
  @@index([regionId])
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String?
  /// Snapshot of product title at order/delete time. Keeps order history readable after a product is removed from the catalog.
  productTitle      String?
  productTitle_ar   String?
  quantity          Int
  perProductMessage String?  @db.Text
  price             Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// ============================================
// PUSH NOTIFICATIONS (FCM) — mobile clients
// ============================================

model UserPushDevice {
  id        String       @id @default(uuid())
  userId    String
  fcmToken  String       @unique @db.Text
  platform  PushPlatform @default(ANDROID)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user toggles for Amoon Bloom push channels. All default true when row is created.
model UserNotificationPreferences {
  userId        String   @id
  orderStatus   Boolean  @default(true)
  promotions    Boolean  @default(true)
  announcements Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Persistent in-app notification record (the "inbox"). Every push we send is also
/// written here so a user who was offline, or whose device token was stale, can still
/// see it — and so the app can show a badge / unread count. `data` mirrors the FCM
/// data payload (e.g. { type, orderId, status }) for deep-linking from the inbox.
model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Inbox query: a user's notifications, newest first, optionally unread-only.
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ============================================
// PROMO CODES
// ============================================

/// Admin-managed discount codes. `appliesTo` controls scope; for SPECIFIC_PRODUCTS or
/// SPECIFIC_CATEGORIES the linked rows in PromoCodeProduct / PromoCodeCategory define the
/// target set. Percentage discounts can be capped via `maxDiscountAmount`. Availability is
/// bounded by `startsAt`/`expiresAt` and total / per-user usage counters.
model PromoCode {
  id             String  @id @default(uuid())
  code           String  @unique
  name           String
  name_ar        String?
  description    String? @db.Text
  description_ar String? @db.Text

  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(10, 2)
  maxDiscountAmount Decimal?     @db.Decimal(10, 2)

  appliesTo PromoAppliesTo @default(ALL_PRODUCTS)

  minOrderAmount Decimal? @db.Decimal(10, 2)
  maxOrderAmount Decimal? @db.Decimal(10, 2)

  startsAt  DateTime?
  expiresAt DateTime?

  usageLimit        Int?
  usageLimitPerUser Int?
  usageCount        Int  @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   PromoCodeProduct[]
  categories PromoCodeCategory[]
  usages     PromoCodeUsage[]
  orders     Order[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model PromoCodeProduct {
  id          String   @id @default(uuid())
  promoCodeId String
  productId   String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@index([promoCodeId])
  @@index([productId])
}

model PromoCodeCategory {
  id          String   @id @default(uuid())
  promoCodeId String
  categoryId  String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, categoryId])
  @@index([promoCodeId])
  @@index([categoryId])
}

/// One row per time a user successfully validates & redeems a promo code. Used to enforce
/// `usageLimit` (global) and `usageLimitPerUser`. `orderId` is null when the discount was
/// only validated and not yet tied to a placed order.
model PromoCodeUsage {
  id             String   @id @default(uuid())
  promoCodeId    String
  userId         String
  orderId        String?
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([userId])
  @@index([promoCodeId, userId])
}

// ============================================
// ENUMS
// ============================================

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

/// Draft/published state for admin-managed content. DRAFT is hidden from the
/// storefront; only PUBLISHED items are returned to non-staff requests.
enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

enum ManagerPermission {
  PRODUCTS
  ORDERS
  CATEGORIES
  SECTIONS
  BANNERS
  CONTACT
  SETTINGS
  PROMO_CODES
  ANALYTICS
  REGIONS
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromoAppliesTo {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  // Online-payment order created but not yet paid. Hidden from order history / admin
  // lists / analytics until payment succeeds, at which point it becomes CONFIRMED.
  AWAITING_PAYMENT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  MYFATOORAH
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
}
