// Amoon Bloom — mobile ecommerce API (Express + Prisma)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & ADMIN
// ============================================

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  fullName           String?
  firstName          String?
  lastName           String?
  password           String?
  googleId           String?   @unique
  appleId            String?   @unique
  avatar             String?
  role               UserRole  @default(CUSTOMER)
  managerTitle       String?
  managerPermissions ManagerPermission[] @default([])
  status             UserStatus @default(ACTIVE)
  isEmailVerified    Boolean   @default(false)
  preferredLanguage  String?
  phone              String?
  addressCountry     String?
  addressCity        String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  cart      Cart?
  orders    Order[]
  addresses Address[]

  pushDevices             UserPushDevice[]
  notificationPreferences UserNotificationPreferences?

  promoCodeUsages PromoCodeUsage[]
}

// ============================================
// SECTIONS (admin-created blocks for user panel, e.g. Ramadan Deals)
// ============================================

model Section {
  id        String   @id @default(uuid())
  title     String
  title_ar  String?
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   SectionProduct[]
  categories SectionCategory[]

  @@index([sortOrder])
}

model SectionProduct {
  id        String   @id @default(uuid())
  sectionId String
  productId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sectionId, productId])
  @@index([sectionId])
  @@index([productId])
}

model SectionCategory {
  id         String   @id @default(uuid())
  sectionId  String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sectionId, categoryId])
  @@index([sectionId])
  @@index([categoryId])
}

// ============================================
// LANDING BANNERS
// ============================================

model BannerImage {
  id        String   @id @default(uuid())
  url       String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

// ============================================
// SETTINGS
// ============================================

model Settings {
  id                String   @id @default("default")
  siteName          String   @default("Amoon Bloom")
  logo              String?
  contactEmail      String   @default("contact@example.com")
  supportEmail      String   @default("support@example.com")
  currency          String   @default("USD")
  maintenanceMode   Boolean  @default(false)
  hiddenPages       String[] @default([])
  updatedAt         DateTime @updatedAt
}

// ============================================
// CONTACT
// ============================================

model ContactMessage {
  id        String   @id @default(uuid())
  firstName String
  lastName  String?
  email     String
  phone     String?
  subject   String   @default("general")
  message   String
  status    String   @default("NEW")
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ============================================
// CATEGORY & PRODUCT
// ============================================

model Category {
  id             String    @id @default(uuid())
  title          String
  title_ar       String?
  description    String?   @db.Text
  description_ar String?   @db.Text
  image          String?
  totalProducts  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products        Product[]
  sectionCategories SectionCategory[]
  promoCodeCategories PromoCodeCategory[]

  @@index([title])
}

model Product {
  id              String   @id @default(uuid())
  title           String
  title_ar        String?
  subtitle        String?
  subtitle_ar     String?
  price           Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)
  quantity        Int      @default(0)
  categoryId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  descriptions   ProductDescription[]
  productOptions ProductOption[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  sectionProducts SectionProduct[]
  promoCodeProducts PromoCodeProduct[]

  @@index([categoryId])
  @@index([title])
}

model ProductOption {
  id         String   @id @default(uuid())
  productId  String
  title      String
  title_ar   String?
  options    String[]
  options_ar String[] @default([])
  sortOrder  Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductDescription {
  id             String   @id @default(uuid())
  productId      String
  title          String?  @db.Text
  title_ar       String?  @db.Text
  description    String   @db.Text
  description_ar String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

// ============================================
// SAVED ADDRESSES
// ============================================

model Address {
  id            String   @id @default(uuid())
  userId        String
  label         String?
  fullName      String?
  phone         String?
  streetAddress String?
  apartment     String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([userId, isDefault])
}

// ============================================
// CART
// ============================================

model Cart {
  id           String    @id @default(uuid())
  userId       String    @unique
  orderMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  message   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ============================================
// ORDER
// ============================================

model Order {
  id                   String        @id @default(uuid())
  userId               String
  orderMessage         String?       @db.Text
  totalAmount          Decimal       @db.Decimal(10, 2)
  discountAmount       Decimal?      @db.Decimal(10, 2)
  appliedPromoCode     String?
  appliedPromoCodeId   String?
  paymentMethod        PaymentMethod @default(COD)
  status               OrderStatus   @default(PENDING)
  /// Soft ref to the saved Address used at checkout (may be null for legacy orders or if address was deleted).
  addressId            String?
  /// Address snapshot — copied from the saved or inline address at checkout time so order history stays accurate.
  shippingFullName     String?
  shippingPhone        String?
  shippingStreetAddress String?
  shippingApartment    String?
  shippingCity         String?
  shippingState        String?
  shippingPostalCode   String?
  shippingCountry      String?
  /// When true, Product.quantity has been reduced for this order’s line items (set on PENDING→CONFIRMED; cleared on cancel/revert).
  inventoryDeducted    Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  address         Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  appliedPromo    PromoCode?  @relation(fields: [appliedPromoCodeId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([createdAt, status])
  @@index([addressId])
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String?
  /// Snapshot of product title at order/delete time. Keeps order history readable after a product is removed from the catalog.
  productTitle      String?
  productTitle_ar   String?
  quantity          Int
  perProductMessage String?  @db.Text
  price             Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// ============================================
// PUSH NOTIFICATIONS (FCM) — mobile clients
// ============================================

model UserPushDevice {
  id        String       @id @default(uuid())
  userId    String
  fcmToken  String       @unique @db.Text
  platform  PushPlatform @default(ANDROID)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user toggles for Amoon Bloom push channels. All default true when row is created.
model UserNotificationPreferences {
  userId        String  @id
  orderStatus   Boolean @default(true)
  promotions    Boolean @default(true)
  announcements Boolean @default(true)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// PROMO CODES
// ============================================

/// Admin-managed discount codes. `appliesTo` controls scope; for SPECIFIC_PRODUCTS or
/// SPECIFIC_CATEGORIES the linked rows in PromoCodeProduct / PromoCodeCategory define the
/// target set. Percentage discounts can be capped via `maxDiscountAmount`. Availability is
/// bounded by `startsAt`/`expiresAt` and total / per-user usage counters.
model PromoCode {
  id                String          @id @default(uuid())
  code              String          @unique
  name              String
  name_ar           String?
  description       String?         @db.Text
  description_ar    String?         @db.Text

  discountType      DiscountType
  discountValue     Decimal         @db.Decimal(10, 2)
  maxDiscountAmount Decimal?        @db.Decimal(10, 2)

  appliesTo         PromoAppliesTo  @default(ALL_PRODUCTS)

  minOrderAmount    Decimal?        @db.Decimal(10, 2)
  maxOrderAmount    Decimal?        @db.Decimal(10, 2)

  startsAt          DateTime?
  expiresAt         DateTime?

  usageLimit        Int?
  usageLimitPerUser Int?
  usageCount        Int             @default(0)

  isActive          Boolean         @default(true)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  products   PromoCodeProduct[]
  categories PromoCodeCategory[]
  usages     PromoCodeUsage[]
  orders     Order[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model PromoCodeProduct {
  id          String   @id @default(uuid())
  promoCodeId String
  productId   String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@index([promoCodeId])
  @@index([productId])
}

model PromoCodeCategory {
  id          String   @id @default(uuid())
  promoCodeId String
  categoryId  String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, categoryId])
  @@index([promoCodeId])
  @@index([categoryId])
}

/// One row per time a user successfully validates & redeems a promo code. Used to enforce
/// `usageLimit` (global) and `usageLimitPerUser`. `orderId` is null when the discount was
/// only validated and not yet tied to a placed order.
model PromoCodeUsage {
  id             String   @id @default(uuid())
  promoCodeId    String
  userId         String
  orderId        String?
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([userId])
  @@index([promoCodeId, userId])
}

// ============================================
// ENUMS
// ============================================

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

enum ManagerPermission {
  PRODUCTS
  ORDERS
  CATEGORIES
  SECTIONS
  BANNERS
  CONTACT
  SETTINGS
  PROMO_CODES
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromoAppliesTo {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
}
