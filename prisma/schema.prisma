// Amoon Bloom — mobile ecommerce API (Express + Prisma)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// REGIONS (multi-region support)
// ============================================

/// A storefront region (e.g. UAE, Saudi Arabia). Regions are data, not an enum, so the
/// admin can add new ones at runtime with no schema migration. `code` is the short token
/// the mobile app sends in the `X-Region` header (e.g. "UAE", "SA"). Exactly one region
/// should have `isDefault = true`; it is used when the client sends no/unknown region.
model Region {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  name_ar   String?
  // ISO 4217 currency code shown/charged for this region (e.g. "AED", "SAR").
  // Drives storefront price display, order currency, and which orders are
  // eligible for online payment (see payment.service's configured currency).
  currency  String   @default("AED")
  // Legal entity name shown in the storefront footer's copyright line for this
  // region (e.g. "AMOON BLOOM Trading L.L.C S.O.C™"). Null falls back to the
  // frontend's default siteConfig.legalEntity, so existing regions keep working
  // without an admin having to backfill this.
  legalEntity String?
  // Flat shipping fee charged on every order placed in this region. Null means
  // no fee has been configured yet — orders ship free until an admin sets one
  // (matches the pre-existing de-facto behavior, so nothing regresses).
  shippingFlatRate Decimal? @db.Decimal(10, 2)
  // ISO 3166-1 alpha-2 code (e.g. "AE", "SA") — renders the region's flag in the
  // storefront's country/region pickers. Null shows a neutral placeholder until
  // an admin sets it (deliberately not required — regions worked without a flag
  // before this field existed).
  iso2 String? @db.VarChar(2)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      ProductRegion[]
  categories    CategoryRegion[]
  banners       BannerRegion[]
  sections      SectionRegion[]
  promoCodes    PromoCodeRegion[]
  users         User[]
  orders        Order[]
  vatConfig     VatConfig?
  deliveryZones DeliveryZone[]

  @@index([isActive])
  @@index([sortOrder])
}

/// Admin-managed delivery sub-areas within a region (e.g. UAE's emirates:
/// Dubai, Abu Dhabi, Sharjah, ...). Scoped per-region (not a global list) so a
/// different region can have its own list later with no schema change —
/// mirrors the Region -> VatConfig relationship.
model DeliveryZone {
  id        String   @id @default(uuid())
  regionId  String
  name      String
  name_ar   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)
  addresses Address[]

  @@unique([regionId, name])
  @@index([regionId])
  @@index([isActive])
}

/// Join: which regions a product is visible in. A row per (product, region) pair —
/// "both regions" = two rows, "UAE only" = one row. No rows = visible in none.
model ProductRegion {
  productId String
  regionId  String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([productId, regionId])
  @@index([regionId])
}

model CategoryRegion {
  categoryId String
  regionId   String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([categoryId, regionId])
  @@index([regionId])
}

model BannerRegion {
  bannerId  String
  regionId  String
  createdAt DateTime @default(now())

  banner BannerImage @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  region Region      @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([bannerId, regionId])
  @@index([regionId])
}

model SectionRegion {
  sectionId String
  regionId  String
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([sectionId, regionId])
  @@index([regionId])
}

// ============================================
// USER & ADMIN
// ============================================

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  fullName           String?
  password           String?
  googleId           String?             @unique
  appleId            String?             @unique
  avatar             String?
  role               UserRole            @default(CUSTOMER)
  managerTitle       String?
  managerPermissions ManagerPermission[] @default([])
  status             UserStatus          @default(ACTIVE)
  isEmailVerified    Boolean             @default(false)
  preferredLanguage  String?
  phone              String?
  /// Region the user belongs to (captured from X-Region at signup). Drives which
  /// regional catalog they browse by default. Nullable for legacy users (backfilled).
  regionId           String?
  addressCountry     String?
  addressCity        String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  /// Bumped to invalidate all currently-issued access tokens for this user.
  /// New JWTs include this value as `tv`; verifyToken rejects mismatches.
  /// Backwards compatible: legacy tokens without `tv` are still accepted
  /// during the rollout window.
  tokenVersion       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  cart      Cart?
  orders    Order[]
  addresses Address[]

  pushDevices             UserPushDevice[]
  notificationPreferences UserNotificationPreferences?
  notifications           Notification[]

  promoCodeUsages PromoCodeUsage[]
  userContacts    UserContact[]
  refreshTokens   RefreshToken[]
  reviews         Review[]

  region Region? @relation(fields: [regionId], references: [id], onDelete: SetNull)

  @@index([regionId])
}

/// Server-side refresh-token store. The raw token is shown to the client once
/// in the auth response and is never persisted in plaintext — only its SHA-256
/// hash. Rotating on every refresh and revoking on logout/password-change is
/// what gives long-lived sessions a safe revocation path.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  /// Tracks which device requested the original sign-in (informational only).
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// SECTIONS (admin-created blocks for user panel, e.g. Ramadan Deals)
// ============================================

model Section {
  id        String        @id @default(uuid())
  title     String
  title_ar  String?
  image     String?
  sortOrder Int           @default(0)
  status    PublishStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  products   SectionProduct[]
  categories SectionCategory[]
  regions    SectionRegion[]

  @@index([sortOrder])
  @@index([status])
}

model SectionProduct {
  id        String   @id @default(uuid())
  sectionId String
  productId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([sectionId, productId])
  @@index([sectionId])
  @@index([productId])
}

model SectionCategory {
  id         String   @id @default(uuid())
  sectionId  String
  categoryId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sectionId, categoryId])
  @@index([sectionId])
  @@index([categoryId])
}

// ============================================
// LANDING BANNERS
// ============================================

model BannerImage {
  id        String         @id @default(uuid())
  url       String         @db.Text
  sortOrder Int            @default(0)
  status    PublishStatus  @default(DRAFT)
  // Which client this banner targets. MOBILE (default) keeps the existing Flutter
  // app behavior untouched; WEB banners (incl. hero videos) are served only to the
  // website, so the storefront default query never leaks them to the mobile app.
  platform  BannerPlatform @default(MOBILE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  regions BannerRegion[]

  @@index([sortOrder])
  @@index([status])
  @@index([platform])
}

// ============================================
// SETTINGS
// ============================================

model Settings {
  id              String   @id @default("default")
  siteName        String   @default("Amoon Bloom")
  logo            String?
  contactEmail    String   @default("contact@example.com")
  supportEmail    String   @default("support@example.com")
  currency        String   @default("USD")
  maintenanceMode Boolean  @default(false)
  hiddenPages     String[] @default([])
  /// Master switch for the product-reviews feature. When true (default), anyone —
  /// signed in or not — can submit a review (guests provide name + email). When
  /// false, only signed-in customers can submit; guest submissions are rejected.
  allowGuestReviews Boolean @default(true)
  updatedAt       DateTime @updatedAt
}

// ============================================
// VAT / TAX
// ============================================

/// Per-region VAT configuration — ONE ROW PER REGION (UAE 5%, KSA 15%, ...). The admin picks a
/// region and sets its rate, whether it applies to ALL products / SPECIFIC_CATEGORIES /
/// SPECIFIC_PRODUCTS, and whether prices are VAT-inclusive. When `inclusive` is true the
/// catalogue price already contains the tax (nothing is added at checkout — the VAT portion is
/// only extracted for reporting); when false the VAT is added on top of the (discounted) price
/// at checkout. A region with no row here has VAT disabled (treated as a zero/disabled config).
model VatConfig {
  id          String       @id @default(uuid())
  regionId    String       @unique
  /// Master switch. When false, no VAT is ever applied regardless of the other fields.
  enabled     Boolean      @default(false)
  /// VAT rate in percent (0–100), e.g. 5.00 for UAE, 15.00 for KSA.
  ratePercent Decimal      @default(0) @db.Decimal(5, 2)
  /// True = catalogue prices already include this VAT (no addition at checkout).
  inclusive   Boolean      @default(false)
  appliesTo   VatAppliesTo @default(ALL_PRODUCTS)
  updatedAt   DateTime     @updatedAt

  region     Region              @relation(fields: [regionId], references: [id], onDelete: Cascade)
  products   VatConfigProduct[]
  categories VatConfigCategory[]
}

/// Products the VAT applies to when appliesTo = SPECIFIC_PRODUCTS.
model VatConfigProduct {
  vatConfigId String
  productId   String
  createdAt   DateTime @default(now())

  vatConfig VatConfig @relation(fields: [vatConfigId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([vatConfigId, productId])
  @@index([productId])
}

/// Categories the VAT applies to when appliesTo = SPECIFIC_CATEGORIES. A product is taxed
/// when its own category is listed here.
model VatConfigCategory {
  vatConfigId String
  categoryId  String
  createdAt   DateTime @default(now())

  vatConfig VatConfig @relation(fields: [vatConfigId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([vatConfigId, categoryId])
  @@index([categoryId])
}

// ============================================
// CONTACT
// ============================================

/// Contact / issue submitted by an authenticated user. Always tied to a User
/// so the admin sees who sent it (name, email, phone) via the join.
model UserContact {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  message   String   @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CATEGORY & PRODUCT
// ============================================

model Category {
  id             String        @id @default(uuid())
  title          String
  title_ar       String?
  description    String?       @db.Text
  description_ar String?       @db.Text
  image          String?
  totalProducts  Int           @default(0)
  status         PublishStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  products            Product[]
  sectionCategories   SectionCategory[]
  promoCodeCategories PromoCodeCategory[]
  vatConfigCategories VatConfigCategory[]
  regions             CategoryRegion[]

  @@index([title])
  @@index([status])
}

model Product {
  id                 String        @id @default(uuid())
  title              String
  title_ar           String?
  subtitle           String?
  subtitle_ar        String?
  price              Decimal       @db.Decimal(10, 2)
  discountedPrice    Decimal?      @db.Decimal(10, 2)
  // Optional Saudi Riyal price override, entered manually by the admin (no
  // auto FX conversion). Null means "no SAR price set yet" — storefront/order
  // pricing falls back to the AED price above for a Saudi-region request.
  priceSar           Decimal?      @db.Decimal(10, 2)
  discountedPriceSar Decimal?      @db.Decimal(10, 2)
  // Gift card add-on: free personalized message at add-to-cart time. Enabled per
  // product to mirror the client site, where most (but not all) products offer it.
  giftCardEnabled    Boolean       @default(false)
  giftCardExtraPrice Decimal?      @db.Decimal(10, 2)
  // Custom name add-on: customer types a name at add-to-cart time for an extra
  // fee. Only enabled on select products (mugs/cups/boxes), never bouquets.
  customNameEnabled  Boolean       @default(false)
  customNamePrice    Decimal?      @db.Decimal(10, 2)
  quantity           Int           @default(0)
  categoryId         String?
  status             PublishStatus @default(DRAFT)
  // Admin-controlled display order (drag-and-drop). Defaults to 0 so existing
  // products keep their createdAt-desc order until an admin reorders them.
  sortOrder          Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  category          Category?            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images            ProductImage[]
  descriptions      ProductDescription[]
  productOptions    ProductOption[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  sectionProducts   SectionProduct[]
  promoCodeProducts PromoCodeProduct[]
  vatConfigProducts VatConfigProduct[]
  regions           ProductRegion[]
  reviews           Review[]

  @@index([categoryId])
  @@index([title])
  // Composite serves the hot storefront query: WHERE status='PUBLISHED' ORDER BY createdAt DESC.
  // Leftmost prefix also covers plain status-equality filters/counts.
  @@index([status, createdAt])
  // Serves the admin-ordered list: WHERE status=? ORDER BY sortOrder ASC, createdAt DESC.
  @@index([status, sortOrder])
}

/// A customer star-rating + written review for a product. Either `userId` is set
/// (signed-in reviewer) or `guestName`/`guestEmail` are set (guest reviewer, only
/// accepted when Settings.allowGuestReviews is true) — never both, never neither.
/// Published immediately (no pending/approval state) — admins moderate after the
/// fact by deleting any review via the admin Reviews page.
model Review {
  id         String   @id @default(uuid())
  productId  String
  userId     String?
  guestName  String?
  guestEmail String?
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([productId, createdAt])
  @@index([userId])
}

model ProductOption {
  id              String   @id @default(uuid())
  productId       String
  title           String
  title_ar        String?
  options         String[]
  options_ar      String[] @default([])
  // Optional per-value image URLs, aligned by index with `options` (e.g. a
  // "Colour" option maps Blue/Pink/White to specific product photos). Empty by
  // default — purely additive, so existing API consumers (the mobile app) are
  // unaffected. An entry may be "" when a value has no dedicated image.
  optionImages    String[] @default([])
  // Optional per-value swatch colours (CSS hex, e.g. "#c2185b" for a custom
  // "dark pink"), aligned by index with `options`. Let admins pick an exact
  // colour instead of relying on name→swatch guessing. Empty by default and
  // purely additive, so the mobile app (which doesn't read it) is unaffected.
  optionColors    String[] @default([])
  // Optional per-value image SETS: a JSON array-of-arrays aligned by index with
  // `options`, so a value (e.g. a colour) can carry several photos. The first of
  // each set is mirrored into `optionImages` above, which the mobile app keeps
  // reading — so this is purely additive and mobile-safe. Null when unused.
  optionImageSets Json?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductDescription {
  id             String   @id @default(uuid())
  productId      String
  title          String?  @db.Text
  title_ar       String?  @db.Text
  description    String   @db.Text
  description_ar String?  @db.Text
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

// ============================================
// SAVED ADDRESSES
// ============================================

model Address {
  id            String   @id @default(uuid())
  userId        String
  label         String?
  fullName      String?
  phone         String?
  streetAddress String?
  apartment     String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  // Free-text neighborhood/community, e.g. "Al Barsha" — replaces streetAddress
  // as the primary location detail in the current checkout form.
  area           String?
  deliveryZoneId String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isDefault])
  @@index([deliveryZoneId])
}

// ============================================
// CART
// ============================================

model Cart {
  id           String   @id @default(uuid())
  userId       String   @unique
  orderMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
}

model CartItem {
  id              String   @id @default(uuid())
  cartId          String
  productId       String
  quantity        Int      @default(1)
  message         String?  @db.Text
  /// Chosen variant, e.g. {"Colour":"Pink","Size":"M"} — keyed by the product's
  /// ProductOption.title. Carried through to OrderItem.selectedOptions at checkout.
  selectedOptions Json?
  // Gift card / custom name add-on selections. `message` above doubles as the
  // gift card's personalized note when giftCardSelected is true.
  giftCardSelected Boolean @default(false)
  customName       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ============================================
// ORDER
// ============================================

model Order {
  id                    String        @id @default(uuid())
  /// Human-friendly sequential order number (Shopify-style, starts at 1001). Backed by a
  /// Postgres sequence; assigned by the DB on insert. Unique and shown to customers/staff
  /// instead of the raw UUID.
  orderNumber           Int           @unique @default(dbgenerated("nextval('order_number_seq'::regclass)"))
  /// Owning customer. NULL for guest (unauthenticated) checkout — such orders carry
  /// the contact snapshot in guestName/guestPhone/guestEmail and are back-linked to a
  /// user account later when someone signs up/in with the same email (see
  /// order.service.linkGuestOrdersToUser).
  userId                String?
  /// Guest checkout contact snapshot (only set when userId is NULL). guestEmail is the
  /// account-linking key and is stored trimmed + lowercased to match auth's normalization.
  guestName             String?
  guestPhone            String?
  guestEmail            String?
  orderMessage          String?       @db.Text
  totalAmount           Decimal       @db.Decimal(10, 2)
  discountAmount        Decimal?      @db.Decimal(10, 2)
  /// Total VAT for this order (order currency). For EXCLUSIVE VAT this is added on top of the
  /// net (discounted) amount and is part of totalAmount; for INCLUSIVE VAT it is the tax
  /// portion already inside the line prices and is NOT added to totalAmount. 0 when no VAT.
  taxAmount             Decimal       @default(0) @db.Decimal(10, 2)
  /// Pre-VAT, pre-discount sum of live line prices (order currency). Null for legacy orders.
  subtotalAmount        Decimal?      @db.Decimal(10, 2)
  /// VAT rate snapshot (percent) applied at checkout. Null when no VAT applied.
  vatRatePercent        Decimal?      @db.Decimal(5, 2)
  /// Whether prices were VAT-inclusive at checkout (tax already inside the price). When true,
  /// taxAmount is the portion inside totalAmount; when false it was added on top of the net.
  vatInclusive          Boolean       @default(false)
  appliedPromoCode      String?
  appliedPromoCodeId    String?
  paymentMethod         PaymentMethod @default(COD)
  status                OrderStatus   @default(PENDING)
  /// Online-payment state. COD orders stay UNPAID until delivered/collected; MyFatoorah orders flip to PAID once GetPaymentStatus confirms it.
  paymentStatus         PaymentStatus @default(UNPAID)
  /// MyFatoorah InvoiceId returned by SendPayment (the payment we created for this order). Null for COD.
  paymentInvoiceId      String?
  /// MyFatoorah transaction/payment id captured at confirmation (from GetPaymentStatus). Null for COD.
  paymentTransactionId  String?
  /// Soft ref to the saved Address used at checkout (may be null for legacy orders or if address was deleted).
  addressId             String?
  /// Address snapshot — copied from the saved or inline address at checkout time so order history stays accurate.
  shippingFullName      String?
  shippingPhone         String?
  shippingStreetAddress String?
  shippingApartment     String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  /// Area/neighborhood free text, snapshot from the address used at checkout.
  shippingArea          String?
  /// Delivery zone (e.g. emirate) NAME snapshot — not an FK, so renaming/deleting
  /// the zone later never alters historical orders (same reasoning as vatRatePercent).
  shippingZoneName      String?
  /// Flat shipping fee charged on this order, snapshot from Region.shippingFlatRate
  /// at checkout time. Null/0 = free (no rate configured for the region at the time).
  shippingAmount        Decimal?      @db.Decimal(10, 2)
  /// When true, Product.quantity has been reduced for this order’s line items (set on PENDING→CONFIRMED; cleared on cancel/revert).
  inventoryDeducted     Boolean       @default(false)
  /// Whether placing this order should clear the user's cart. True for normal cart checkout;
  /// false for "Buy Now" (single-product direct purchase) so the cart is left untouched.
  clearCartOnPayment    Boolean       @default(true)
  /// Region the order was placed in (captured from X-Region / the user's region at checkout).
  /// Drives region-scoped analytics. Nullable for legacy orders (backfilled to default region).
  regionId              String?
  /// Currency the order was totaled/charged in (e.g. "AED", "SAR") — snapshot of the
  /// order region's currency at placement. Null for legacy orders placed before
  /// multi-currency (treat as the store's default, AED).
  currency              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  address      Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  appliedPromo PromoCode?  @relation(fields: [appliedPromoCodeId], references: [id], onDelete: SetNull)
  region       Region?     @relation(fields: [regionId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([guestEmail])
  @@index([status])
  @@index([createdAt])
  @@index([createdAt, status])
  @@index([addressId])
  @@index([regionId])
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String?
  /// Snapshot of product title at order/delete time. Keeps order history readable after a product is removed from the catalog.
  productTitle      String?
  productTitle_ar   String?
  quantity          Int
  perProductMessage String?  @db.Text
  price             Decimal  @db.Decimal(10, 2)
  /// VAT rate applied to this line (percent). 0/null when the line is untaxed (outside the
  /// VAT scope, or VAT disabled).
  vatRatePercent    Decimal? @db.Decimal(5, 2)
  /// VAT amount for the whole line (quantity included), order currency. For inclusive VAT
  /// this is the portion already inside `price`; for exclusive it was added on top.
  vatAmount         Decimal? @db.Decimal(10, 2)
  /// Variant chosen at add-to-cart time, snapshotted onto the order line (e.g.
  /// {"Colour":"Pink"}). Null for orders placed before this was captured.
  selectedOptions   Json?
  // Gift card / custom name add-on selections, snapshotted at order time.
  // perProductMessage above doubles as the gift card's note when set.
  giftCardSelected  Boolean  @default(false)
  customName        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

// ============================================
// PUSH NOTIFICATIONS (FCM) — mobile clients
// ============================================

model UserPushDevice {
  id        String       @id @default(uuid())
  userId    String
  fcmToken  String       @unique @db.Text
  platform  PushPlatform @default(ANDROID)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user toggles for Amoon Bloom push channels. All default true when row is created.
model UserNotificationPreferences {
  userId        String   @id
  orderStatus   Boolean  @default(true)
  promotions    Boolean  @default(true)
  announcements Boolean  @default(true)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Persistent in-app notification record (the "inbox"). Every push we send is also
/// written here so a user who was offline, or whose device token was stale, can still
/// see it — and so the app can show a badge / unread count. `data` mirrors the FCM
/// data payload (e.g. { type, orderId, status }) for deep-linking from the inbox.
model Notification {
  id        String    @id @default(uuid())
  /// Null for a notification created before the recipient had an account (see
  /// guestEmail below) — same nullable-then-claimed pattern as Order.userId.
  userId    String?
  /// Guest checkout contact snapshot (only set when userId is NULL), normalized
  /// (trim+lowercase) like Order.guestEmail. linkGuestOrdersToUser re-points
  /// these rows to the new account on signup/login, matching the same email.
  guestEmail String?
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Inbox query: a user's notifications, newest first, optionally unread-only.
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([guestEmail])
}

// ============================================
// PROMO CODES
// ============================================

/// Admin-managed discount codes. `appliesTo` controls scope; for SPECIFIC_PRODUCTS or
/// SPECIFIC_CATEGORIES the linked rows in PromoCodeProduct / PromoCodeCategory define the
/// target set. Percentage discounts can be capped via `maxDiscountAmount`. Availability is
/// bounded by `startsAt`/`expiresAt` and total / per-user usage counters.
model PromoCode {
  id             String  @id @default(uuid())
  code           String  @unique
  name           String
  name_ar        String?
  description    String? @db.Text
  description_ar String? @db.Text

  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(10, 2)
  maxDiscountAmount Decimal?     @db.Decimal(10, 2)

  appliesTo PromoAppliesTo @default(ALL_PRODUCTS)

  minOrderAmount Decimal? @db.Decimal(10, 2)
  maxOrderAmount Decimal? @db.Decimal(10, 2)

  startsAt  DateTime?
  expiresAt DateTime?

  usageLimit        Int?
  usageLimitPerUser Int?
  usageCount        Int  @default(0)

  /// When true, only "new" customers may redeem this code — a user whose account
  /// was created within the last `newUserWithinDays` days. Account-age based (not
  /// first-order), so the window is configurable per code.
  newUsersOnly      Boolean @default(false)
  /// Account-age window in days for `newUsersOnly`. Eligible when
  /// (now - user.createdAt) <= this many days. Null falls back to a server default.
  newUserWithinDays Int?

  isActive Boolean @default(true)

  /// Set once the "new promo is now active" notification has been broadcast to users,
  /// so the daily announce job never notifies the same code twice. Null = not yet
  /// announced (a freshly created, not-yet-started code).
  announcedAt DateTime?

  /// When false, the code is silent — the daily announce job never broadcasts it to users
  /// (for internal/staff codes). Default true so normal promos auto-announce when active.
  announceToUsers Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   PromoCodeProduct[]
  categories PromoCodeCategory[]
  usages     PromoCodeUsage[]
  orders     Order[]
  // Regions this code can be redeemed in. Mirrors Product/Category/Section/Banner:
  // omitted on create -> defaults to the default region (UAE) only.
  regions    PromoCodeRegion[]

  @@index([code])
  @@index([isActive])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([createdAt])
}

model PromoCodeRegion {
  promoCodeId String
  regionId    String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  region    Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([promoCodeId, regionId])
  @@index([regionId])
}

model PromoCodeProduct {
  id          String   @id @default(uuid())
  promoCodeId String
  productId   String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@index([promoCodeId])
  @@index([productId])
}

model PromoCodeCategory {
  id          String   @id @default(uuid())
  promoCodeId String
  categoryId  String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, categoryId])
  @@index([promoCodeId])
  @@index([categoryId])
}

/// One row per time a user successfully validates & redeems a promo code. Used to enforce
/// `usageLimit` (global) and `usageLimitPerUser`. `orderId` is null when the discount was
/// only validated and not yet tied to a placed order.
model PromoCodeUsage {
  id             String   @id @default(uuid())
  promoCodeId    String
  /// Redeeming customer. NULL when the code was applied on a guest (unauthenticated)
  /// order; re-pointed to the user if that guest order is later linked to an account.
  userId         String?
  orderId        String?
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
  @@index([userId])
  @@index([promoCodeId, userId])
}

// ============================================
// ENUMS
// ============================================

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

/// Draft/published state for admin-managed content. DRAFT is hidden from the
/// storefront; only PUBLISHED items are returned to non-staff requests.
enum PublishStatus {
  DRAFT
  PUBLISHED
}

/// Which client a banner targets. MOBILE (default) preserves the existing Flutter
/// app behavior; WEB banners (including hero videos) are served only to the website.
enum BannerPlatform {
  MOBILE
  WEB
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

enum ManagerPermission {
  PRODUCTS
  ORDERS
  CATEGORIES
  SECTIONS
  BANNERS
  CONTACT
  SETTINGS
  PROMO_CODES
  ANALYTICS
  REGIONS
  REVIEWS
  DELIVERY_ZONES
  VAT
  NOTIFICATIONS
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

/// Scope selector for the store-wide VAT config (mirrors PromoAppliesTo).
enum VatAppliesTo {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

enum PromoAppliesTo {
  ALL_PRODUCTS
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  // Online-payment order created but not yet paid. Hidden from order history / admin
  // lists / analytics until payment succeeds, at which point it becomes CONFIRMED.
  AWAITING_PAYMENT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  MYFATOORAH
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
}
