{
  "name": "amoon-bloom-api",
  "version": "1.0.0",
  "description": "Amoon Bloom mobile ecommerce API — Express, Prisma, PostgreSQL, FCM push",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "node worker.js",
    "seed": "node prisma/seed.js",
    "dev": "nodemon server.js",
    "build": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "e2e": "node scripts/e2e-test.js",
    "test:promo": "node scripts/test-promo-codes.js",
    "test:permissions": "node scripts/manager-permissions-test.js",
    "test:search": "node scripts/search-verify.js",
    "test:cart": "node scripts/cart-verify.js",
    "test:notifications": "node scripts/notifications-verify.js",
    "test:promo-verify": "node scripts/promo-verify.js",
    "test:vat": "node scripts/vat-verify.js",
    "test:vat-integration": "node scripts/vat-integration-test.js",
    "kill-port-5000": "powershell -ExecutionPolicy Bypass -File scripts/kill-port-5000.ps1",
    "migrate:fix-p3009": "node scripts/fix-p3009-ecommerce-migration.js"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "ecommerce",
    "api"
  ],
  "author": "",
  "license": "ISC",
