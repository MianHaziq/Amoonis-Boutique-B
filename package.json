    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.19.1",
    "pg": "^8.17.2",
    "pg-boss": "^10.4.2",
    "prisma": "^7.3.0",
    "resend": "^6.9.3",
    "svg-to-pdfkit": "^0.1.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
