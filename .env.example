# Server Configuration
# Local dev: use the SAME port in mobile/web app base URL (e.g. http://localhost:PORT/api/v1).
PORT=5000
# Required in production (Railway, etc.) — app will not start without it
JWT_SECRET=your-jwt-secret

# Database Configuration
DATABASE_URL=your-database-url

# Docker / Railway: optional one-time seed on startup (start.sh). Default: do not set.
# RUN_SEED=true

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=your-apple-services-id-or-bundle-id

# MyFatoorah Payments (Apple Pay + cards via hosted page) — optional
# Generate the API token in the MyFatoorah dashboard: Create New Token → copy
# the long generated string into MYFATOORAH_API_KEY. Keep it secret.
# Base URL: test = https://apitest.myfatoorah.com ; live (UAE/AED) = https://api.myfatoorah.com
# Callback/Error URLs must point at THIS backend's public URL.
MYFATOORAH_API_KEY=your-myfatoorah-token
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
MYFATOORAH_CALLBACK_URL=https://your-backend-domain.com/api/v1/orders/payment/callback
MYFATOORAH_ERROR_URL=https://your-backend-domain.com/api/v1/orders/payment/error

# Firebase Cloud Messaging (optional — push disabled if unset)
# Download a service account JSON from Firebase Console → Project settings → Service accounts.
# Prefer BASE64 in production (single line) to avoid escaping issues.
# FIREBASE_SERVICE_ACCOUNT_BASE64=<base64-encoded entire JSON file>
# Or one-line JSON (escape quotes carefully):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

